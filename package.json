{
  "name": "pricefeed",
  "version": "1.1.0",
  "description": "Price feed publisher for Steem witnesses",
  "main": "feed.js",
  "scripts": {
    "test": "node --test",
    "start": "node feed.js",
    "check": "node --check feed.js",
    "lint": "for f in feed.js src/*.js test/*.js; do node --check \"$f\" || exit 1; done",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "ci": "npm run lint && npm run test && npm run format"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MattyIce/pricefeed.git"
  },
  "author": "yabapmatt",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MattyIce/pricefeed/issues"
  },
  "homepage": "https://github.com/MattyIce/pricefeed#readme",
  "dependencies": {
    "punycode": "^2.3.1",
    "steem": "^0.7.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
