# Copy this file to .env and fill in your witness credentials.
# docker-compose automatically loads variables from .env.
#
# These are also picked up by the price feed at runtime via the
# ${FEED_STEEM_ACCOUNT} / ${FEED_STEEM_ACTIVE_KEY} placeholders in config.yaml.

FEED_STEEM_ACCOUNT=
FEED_STEEM_ACTIVE_KEY=

# Optional: API key for the `cryptocompare` price source. The source works
# without a key but is rate-limited; set this to raise your limits.
CRYPTOCOMPARE_API_KEY=
